# ── Media servers ─────────────────────────────────────────────────────────────
# Enable at least one. Both may be enabled at once (each is scanned independently
# per path, via their own *_SECTION_MAPPING below). PLEX_ENABLED defaults to true
# so existing installs keep working without setting anything here.
PLEX_ENABLED=true
JELLYFIN_ENABLED=false

# ── Plex ──────────────────────────────────────────────────────────────────────
PLEX_URL=http://192.168.1.100:32400
PLEX_TOKEN=your-plex-token-here
PLEXAPI_HEADER_IDENTIFIER=media-servarr-sync
TZ=America/New_York
PLEX_TIMEOUT=60

# ── Jellyfin (only used when JELLYFIN_ENABLED=true) ────────────────────────────
JELLYFIN_URL=http://192.168.1.100:8096
# Create under Jellyfin: Dashboard → API Keys → +
JELLYFIN_API_KEY=your-jellyfin-api-key-here
JELLYFIN_TIMEOUT=60

# ── UI theme ──────────────────────────────────────────────────────────────────
# "plex" (amber) or "jellyfin" (purple). Leave unset to auto-match whichever
# single server type is enabled. When both are enabled this is just the initial
# default — a toggle appears in the header to switch per-browser.
UI_THEME=

# ── Rclone (set USE_RCLONE=false if you don't use an rclone VFS mount) ────────
USE_RCLONE=false
RCLONE_RC_URL=http://192.168.1.100:5572
RCLONE_RC_USER=
RCLONE_RC_PASS=
RCLONE_MOUNT_ROOT=/mnt/media

# ── Timing ────────────────────────────────────────────────────────────────────
WEBHOOK_DELAY=30
MINIMUM_AGE=0
SYNC_COOLDOWN=5m

# ── History ───────────────────────────────────────────────────────────────────
HISTORY_DAYS=7

# ── Sonarr / Radarr (optional — enables quality profile & custom format lookups) ──
SONARR_URL=http://192.168.1.100:8989
SONARR_API_KEY=
RADARR_URL=http://192.168.1.100:7878
RADARR_API_KEY=

# ── Path mappings ─────────────────────────────────────────────────────────────
PATH_REPLACEMENTS={ "/data/tv": "/mnt/media/tv", "/data/movies": "/mnt/media/movies" }
RCLONE_PATH_REPLACEMENTS={ "/data/tv": "/mnt/media/tv", "/data/movies": "/mnt/media/movies" }
# Plex library section IDs — find yours at:
#   http://YOUR_PLEX_IP:32400/library/sections?X-Plex-Token=YOUR_TOKEN
SECTION_MAPPING={ "/mnt/media/tv": "1", "/mnt/media/movies": "2" }
# Jellyfin library ItemIds — find yours via Dashboard → Libraries (or GET
# {JELLYFIN_URL}/Library/VirtualFolders with your API key). Only used when
# JELLYFIN_ENABLED=true.
JELLYFIN_SECTION_MAPPING={ "/mnt/media/tv": "", "/mnt/media/movies": "" }

# ── Manual UI ─────────────────────────────────────────────────────────────────
MANUAL_USER=admin
MANUAL_PASS=changeme
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# ── Volume / port ─────────────────────────────────────────────────────────────
# MEDIA_ROOT     = host path to your media (mounted into the container)
# CONTAINER_MEDIA = path inside this container where media is mounted
#                   This must match the path Plex uses to see your files.
#                   Used as the mount target and for MINIMUM_AGE file-age checks.
MEDIA_ROOT=/mnt/media
CONTAINER_MEDIA=/mnt/media
PORT=5000
